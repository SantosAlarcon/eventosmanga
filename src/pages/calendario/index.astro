---
import Calendar from "../../components/Calendar.jsx";
import MainLayout from "../../layouts/MainLayout.astro";
---

<MainLayout title="Calendario - Eventos Manga" description="Calendario completo de todos los eventos manga, salones y convenciones anime en España. Consulta fechas, horarios y ubicaciones de cada evento.">
    <section class="calendario">
        <h1 class="calendario__title">Calendario</h1>
        <div class="calendario__content">
            <Calendar client:idle />
        </div>
    </section>
</MainLayout>

<script type="application/ld+json" is:inline>
    {
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        "itemListElement": [
            {
                "@type": "ListItem",
                "position": 1,
                "name": "Eventos Manga",
                "item": "https://www.eventosmanga.es"
            },
            {
                "@type": "ListItem",
                "position": 2,
                "name": "Calendario"
            }
        ]
    }
</script>

<style>
    .calendario {
        padding: 3rem;
        color: var(--foreground);

        @media (width <= 640px) {
            padding: 1.25rem;
        }
    }

    .calendario__title {
        color: var(--foreground);
        font-size: 2.25rem;
    }

    .calendario__content {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 1rem;
    }
</style>
